{
  "$description": "VoxPress design tokens. Drop-in for tailwind.config.ts theme.extend or Style Dictionary.",
  "color": {
    "bg": { "DEFAULT": "#f4f5f7", "2": "#eceef2" },
    "panel": "#ffffff",
    "ink": {
      "DEFAULT": "#0f1419",
      "2": "#3d4550",
      "3": "#7b8594",
      "4": "#b6bdc8"
    },
    "line": {
      "DEFAULT": "#e2e5eb",
      "2": "#eef0f4",
      "strong": "#d0d5de"
    },
    "accent": {
      "DEFAULT": "#4f5d75",
      "2": "#2d3748",
      "soft": "#eef1f6",
      "tint": "#dde3ec"
    },
    "ok": { "DEFAULT": "#4a7c59", "soft": "#e8efe9" },
    "warn": { "DEFAULT": "#9c6f1e", "soft": "#f6efdf" },
    "danger": "#9c4a4a"
  },
  "fontFamily": {
    "sans": ["Noto Sans SC", "-apple-system", "BlinkMacSystemFont", "PingFang SC", "Hiragino Sans GB", "sans-serif"],
    "mono": ["IBM Plex Mono", "ui-monospace", "SF Mono", "Menlo", "monospace"],
    "serif": ["Instrument Serif", "Noto Serif SC", "Georgia", "serif"]
  },
  "fontSize": {
    "xs":   ["11px", { "lineHeight": "1.55" }],
    "sm":   ["12px", { "lineHeight": "1.55" }],
    "base": ["13.5px", { "lineHeight": "1.55" }],
    "md":   ["14px", { "lineHeight": "1.55" }],
    "lg":   ["16px", { "lineHeight": "1.5" }],
    "xl":   ["19px", { "lineHeight": "1.3" }],
    "2xl":  ["22px", { "lineHeight": "1.2" }],
    "3xl":  ["26px", { "lineHeight": "1.1" }],
    "4xl":  ["32px", { "lineHeight": "1.2" }]
  },
  "letterSpacing": {
    "tighter": "-0.025em",
    "tight":   "-0.02em",
    "snug":    "-0.015em",
    "normal":  "0",
    "wide":    "0.06em",
    "wider":   "0.1em"
  },
  "borderRadius": {
    "sm":   "4px",
    "DEFAULT": "6px",
    "md":   "8px",
    "lg":   "10px",
    "xl":   "12px",
    "full": "999px"
  },
  "spacing": {
    "1":  "4px",
    "2":  "8px",
    "3":  "12px",
    "4":  "16px",
    "5":  "20px",
    "6":  "24px",
    "7":  "28px",
    "8":  "32px",
    "10": "40px",
    "12": "48px",
    "16": "64px"
  },
  "boxShadow": {
    "sm": "0 1px 2px rgba(15,20,25,0.04), 0 1px 1px rgba(15,20,25,0.02)",
    "md": "0 2px 8px rgba(15,20,25,0.05), 0 1px 3px rgba(15,20,25,0.03)",
    "lg": "0 12px 32px rgba(15,20,25,0.08), 0 2px 6px rgba(15,20,25,0.04)"
  },
  "transitionTimingFunction": {
    "default": "cubic-bezier(0.4, 0, 0.2, 1)"
  },
  "transitionDuration": {
    "fast":   "120ms",
    "normal": "150ms",
    "slow":   "400ms"
  },
  "avatarGradients": [
    "linear-gradient(135deg,#5a6b8a,#3d4a63)",
    "linear-gradient(135deg,#7a6b5a,#5a4a3a)",
    "linear-gradient(135deg,#5a7a8a,#3a5a6a)",
    "linear-gradient(135deg,#8a6b7a,#6a4a5a)",
    "linear-gradient(135deg,#6b8a7a,#4a6a5a)",
    "linear-gradient(135deg,#6b5a8a,#4a3a6a)",
    "linear-gradient(135deg,#8a7a5a,#6a5a3a)",
    "linear-gradient(135deg,#5a8a6b,#3a6a4a)",
    "linear-gradient(135deg,#8a5a6b,#6a3a4a)"
  ],
  "thumbGradients": [
    "linear-gradient(135deg,#dde3ec,#b8c1d0)",
    "linear-gradient(135deg,#e6dfd3,#c8bfad)",
    "linear-gradient(135deg,#d6e0e6,#b0becb)",
    "linear-gradient(135deg,#e3dae0,#c5b6bf)",
    "linear-gradient(135deg,#dae3db,#b6c6b9)"
  ]
}
