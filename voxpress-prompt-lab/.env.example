# DashScope（阿里云百炼）API Key —— 与 voxpress-api 用的同一个 key 即可
DASHSCOPE_API_KEY=sk-your-dashscope-api-key

# DashScope OpenAI 兼容模式 endpoint（一般不用改）
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 默认 organize 模型
PL_DEFAULT_MODEL=qwen3.6-plus

# 默认 temperature（organize 阶段建议 0.3–0.4）
PL_DEFAULT_TEMPERATURE=0.3

# 默认 max_tokens
PL_DEFAULT_MAX_TOKENS=4000

# 多 case 并发执行数（每个 case 一次 multi_pass 是 3 次串行 LLM call，并发是跨 case 的）
PL_CONCURRENCY=2
