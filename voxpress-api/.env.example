VOXPRESS_DB_URL=postgresql+asyncpg://auston@localhost/voxpress
VOXPRESS_HOST=127.0.0.1
VOXPRESS_PORT=8787
VOXPRESS_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
VOXPRESS_DASHSCOPE_API_KEY=sk-xxx
VOXPRESS_DASHSCOPE_COMPATIBLE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VOXPRESS_DASHSCOPE_DEFAULT_LLM_MODEL=qwen3.6-plus
VOXPRESS_DASHSCOPE_DEFAULT_CORRECTOR_MODEL=qwen-turbo-latest
VOXPRESS_DASHSCOPE_DEFAULT_ASR_MODEL=qwen3-asr-flash-filetrans
VOXPRESS_DASHSCOPE_LLM_MODELS=qwen3.6-plus,qwen-plus,qwen-plus-latest,qwen-turbo,qwen-flash
VOXPRESS_DASHSCOPE_CORRECTOR_MODELS=qwen-turbo-latest,qwen-turbo,qwen-flash,qwen3.6-plus,qwen-plus
VOXPRESS_DASHSCOPE_ASR_MODELS=qwen3-asr-flash-filetrans
VOXPRESS_DASHSCOPE_CHAT_PRICING={"qwen3.6-plus":[0.002,0.012],"qwen-plus":[0.0008,0.002],"qwen-plus-latest":[0.0008,0.002],"qwen-turbo":[0.0003,0.0006],"qwen-turbo-latest":[0.0003,0.0006]}
VOXPRESS_DASHSCOPE_ASR_PRICING={"qwen3-asr-flash-filetrans":0.00022}
VOXPRESS_AUDIO_DIR=/tmp/voxpress/audio

# stub = placeholder pipeline (no external deps); real = f2 + DashScope Qwen + OSS
VOXPRESS_PIPELINE=stub

# ─── Concurrency (tuned against DashScope default tier) ───
VOXPRESS_MAX_PIPELINE_CONCURRENCY=15
VOXPRESS_DOWNLOAD_CONCURRENCY=8
VOXPRESS_TRANSCRIBE_CONCURRENCY=10
VOXPRESS_CORRECT_CONCURRENCY=15
VOXPRESS_ORGANIZE_CONCURRENCY=12
VOXPRESS_SAVE_CONCURRENCY=4
