#!/usr/bin/env bash
# VoxPress service control вҖ” postgres В· api В· web
# Usage: ./scripts/vp <command> [args]
#   up [api|web|all]          еҗҜеҠЁ(й»ҳи®Ө all:зЎ®дҝқ pg + api + web)
#   down [api|web|all]        еҒңжӯў(й»ҳи®Ө all:еҸӘеҒң api + web,brew жңҚеҠЎдёҚеҠЁ)
#   restart [api|web|all]
#   status                    жҹҘзңӢжүҖжңүжңҚеҠЎ
#   logs <api|web> [-f]       жҹҘзңӢж—Ҙеҝ—(-f и·ҹйҡҸ)
#   pg <start|stop|restart>   з®ЎзҗҶ brew postgresql@16
#   db                        иҝӣе…Ҙ psql voxpress
#   help

set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
API_DIR="$ROOT/voxpress-api"
WEB_DIR="$ROOT/voxpress"
LOG_DIR="/tmp"
API_LOG="$LOG_DIR/voxpress-api.log"
WEB_LOG="$LOG_DIR/voxpress-web.log"
API_PORT=8787
WEB_PORT=5173
PG_PORT=5432

c_reset=$'\033[0m'; c_dim=$'\033[2m'; c_red=$'\033[31m'; c_grn=$'\033[32m'; c_ylw=$'\033[33m'; c_cyn=$'\033[36m'; c_bld=$'\033[1m'

die()  { echo "${c_red}вң—${c_reset} $*" >&2; exit 1; }
info() { echo "${c_cyn}вҶ’${c_reset} $*"; }
ok()   { echo "${c_grn}вң“${c_reset} $*"; }
warn() { echo "${c_ylw}!${c_reset} $*"; }

pid_on_port() { lsof -ti ":$1" -sTCP:LISTEN 2>/dev/null | head -1; }

wait_port() {
  local port=$1 timeout=${2:-15} i=0
  while [ $i -lt "$timeout" ]; do
    if [ -n "$(pid_on_port "$port")" ]; then return 0; fi
    sleep 1; i=$((i + 1))
  done
  return 1
}

kill_port() {
  local port=$1 label=$2 pid
  pid=$(pid_on_port "$port" || true)
  if [ -z "$pid" ]; then
    echo "${c_dim}  $label: жңӘиҝҗиЎҢ${c_reset}"
    return 0
  fi
  info "еҒңжӯў $label (pid=$pid, port=$port)"
  kill "$pid" 2>/dev/null || true
  local i=0
  while [ $i -lt 10 ] && kill -0 "$pid" 2>/dev/null; do sleep 0.5; i=$((i + 1)); done
  if kill -0 "$pid" 2>/dev/null; then
    warn "$label жңӘеңЁ 5s еҶ…йҖҖеҮә,еҸ‘йҖҒ SIGKILL"
    kill -9 "$pid" 2>/dev/null || true
  fi
  ok "$label е·ІеҒңжӯў"
}

start_api() {
  if [ -n "$(pid_on_port $API_PORT)" ]; then
    warn "api е·ІеңЁ :$API_PORT иҝҗиЎҢ (pid=$(pid_on_port $API_PORT)),и·іиҝҮ"
    return 0
  fi
  [ -x "$API_DIR/.venv/bin/uvicorn" ] || die "жңӘжүҫеҲ° $API_DIR/.venv/bin/uvicorn;е…Ҳи·‘ uv sync"
  info "еҗҜеҠЁ api вҶ’ $API_LOG"
  (
    cd "$API_DIR"
    nohup .venv/bin/uvicorn voxpress.main:app --host 127.0.0.1 --port $API_PORT --workers 1 \
      >"$API_LOG" 2>&1 &
    disown
  )
  if wait_port $API_PORT 20; then
    ok "api е·Іе°ұз»Ә http://127.0.0.1:$API_PORT (pid=$(pid_on_port $API_PORT))"
  else
    die "api еҗҜеҠЁеӨұиҙҘ,жҹҘзңӢж—Ҙеҝ—: tail -50 $API_LOG"
  fi
}

start_web() {
  if [ -n "$(pid_on_port $WEB_PORT)" ]; then
    warn "web е·ІеңЁ :$WEB_PORT иҝҗиЎҢ (pid=$(pid_on_port $WEB_PORT)),и·іиҝҮ"
    return 0
  fi
  [ -d "$WEB_DIR/node_modules" ] || die "жңӘе®үиЈ…дҫқиө–;е…Ҳи·‘ bun install жҲ– npm install"
  info "еҗҜеҠЁ web вҶ’ $WEB_LOG"
  (
    cd "$WEB_DIR"
    nohup npx vite --port $WEB_PORT --host 127.0.0.1 >"$WEB_LOG" 2>&1 &
    disown
  )
  if wait_port $WEB_PORT 20; then
    ok "web е·Іе°ұз»Ә http://127.0.0.1:$WEB_PORT (pid=$(pid_on_port $WEB_PORT))"
  else
    die "web еҗҜеҠЁеӨұиҙҘ,жҹҘзңӢж—Ҙеҝ—: tail -50 $WEB_LOG"
  fi
}

stop_api() { kill_port $API_PORT api; }
stop_web() { kill_port $WEB_PORT web; }

ensure_pg() {
  if [ -z "$(pid_on_port $PG_PORT)" ]; then
    info "postgresql@16 жңӘиҝҗиЎҢ,brew services start"
    brew services start postgresql@16 >/dev/null
    wait_port $PG_PORT 15 || die "postgres еҗҜеҠЁеӨұиҙҘ"
  fi
  ok "postgres :$PG_PORT"
}

status_one() {
  local port=$1 label=$2 pid
  pid=$(pid_on_port "$port" || true)
  if [ -n "$pid" ]; then
    printf "  %s  %-8s ${c_grn}running${c_reset}  pid=%s  :%s\n" "вң“" "$label" "$pid" "$port"
  else
    printf "  %s  %-8s ${c_dim}stopped${c_reset}             :%s\n" "В·" "$label" "$port"
  fi
}

cmd_status() {
  echo "${c_bld}VoxPress жңҚеҠЎзҠ¶жҖҒ${c_reset}"
  status_one $PG_PORT  postgres
  status_one $API_PORT api
  status_one $WEB_PORT web
  echo
  echo "${c_dim}logs:  api=$API_LOG  web=$WEB_LOG${c_reset}"
}

cmd_up() {
  local target=${1:-all}
  case "$target" in
    all) ensure_pg; start_api; start_web ;;
    api) ensure_pg; start_api ;;
    web) start_web ;;
    *)   die "жңӘзҹҘзӣ®ж Ү: $target (all|api|web)" ;;
  esac
}

cmd_down() {
  local target=${1:-all}
  case "$target" in
    all) stop_api; stop_web ;;
    api) stop_api ;;
    web) stop_web ;;
    *)   die "жңӘзҹҘзӣ®ж Ү: $target (all|api|web)" ;;
  esac
}

cmd_restart() {
  local target=${1:-all}
  case "$target" in
    all) stop_api; stop_web; ensure_pg; start_api; start_web ;;
    api) stop_api; ensure_pg; start_api ;;
    web) stop_web; start_web ;;
    *)   die "жңӘзҹҘзӣ®ж Ү: $target (all|api|web)" ;;
  esac
}

cmd_logs() {
  local target=${1:-}
  [ -n "$target" ] || die "з”Ёжі•: vp logs <api|web> [-f]"
  local file
  case "$target" in
    api) file="$API_LOG" ;;
    web) file="$WEB_LOG" ;;
    *)   die "жңӘзҹҘзӣ®ж Ү: $target (api|web)" ;;
  esac
  [ -f "$file" ] || die "ж—Ҙеҝ—дёҚеӯҳеңЁ: $file"
  shift
  if [ "${1:-}" = "-f" ]; then
    tail -f "$file"
  else
    tail -60 "$file"
  fi
}

cmd_pg() {
  local action=${1:-status}
  case "$action" in
    start)   brew services start postgresql@16 ;;
    stop)    brew services stop  postgresql@16 ;;
    restart) brew services restart postgresql@16 ;;
    *)       die "з”Ёжі•: vp pg <start|stop|restart>" ;;
  esac
}

cmd_db() { exec psql voxpress; }

cmd_help() {
  awk '/^# VoxPress/{p=1} p && /^# /{sub(/^# ?/,""); print; next} p && !/^#/{exit}' "$0"
}

main() {
  local cmd=${1:-help}
  shift || true
  case "$cmd" in
    up|start)     cmd_up "$@" ;;
    down|stop)    cmd_down "$@" ;;
    restart)      cmd_restart "$@" ;;
    status|ps)    cmd_status ;;
    logs|log)     cmd_logs "$@" ;;
    pg|postgres)  cmd_pg "$@" ;;
    db|psql)      cmd_db ;;
    help|-h|--help) cmd_help ;;
    *)            warn "жңӘзҹҘе‘Ҫд»Ө: $cmd"; cmd_help; exit 1 ;;
  esac
}

main "$@"
